[user]
	name = keob
	email = isgopher@outlook.com
[color]
	branch = always
	status = always
	diff = always
	log = always
	grep = always
	interactive = always
[alias]
	co = checkout
	cob = checkout -b
	cm = commit -m
	ci = commit
	amend = commit --amend -m
	aa = add -A .
	st = status
	br = branch -v
	fo = fetch origin
	fu = fetch upstream
	po = push origin
	unstage = reset HEAD
	uncommit = reset --soft HEAD^
	tags = tag -l
	branches = branch -a
	remotes = remote -v
	contributors = shortlog --summary --numbered
	logg = log --graph --decorate --all
	dog = log --all --decorate --oneline --graph
	ls = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate
	ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat
	la = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all
	lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)' --all
[credential]
	helper = store
