// Place your key bindings in this file to override the defaults
[
    {
        "key": "ctrl+k ctrl+i",
        "command": "go.import.add"
    },
    {
        "key": "ctrl+alt+n",
        "command": "explorer.newFile"
    },
    {
        "key": "ctrl+k ctrl+n",
        "command": "explorer.newFolder"
    },
    {
        "key": "ctrl+k ctrl+m",
        "command": "workbench.action.editor.changeLanguageMode"
    },
    {
        "key": "ctrl+k m",
        "command": "-workbench.action.editor.changeLanguageMode"
    }
]
