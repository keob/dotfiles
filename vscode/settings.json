{
    // basic
    "editor.fontFamily": "Iosevka,Fira Code,JetBrains Mono,Consolas",
    "editor.fontSize": 18,
    "editor.rulers": [
        80
    ],
    "editor.cursorBlinking": "phase",
    "editor.cursorSmoothCaretAnimation": true,
    "editor.smoothScrolling": true,
    "editor.fontLigatures": true,
    "editor.lineNumbers": "on",
    "editor.quickSuggestionsDelay": 3,
    "editor.snippetSuggestions": "inline",
    "editor.suggest.showSnippets": true,
    "editor.renderWhitespace": "selection",
    "editor.wordWrap": "on",
    "explorer.compactFolders": false,
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.links": false,
    "editor.minimap.enabled": true,
    "editor.acceptSuggestionOnEnter": "off",
    "editor.parameterHints.enabled": true,
    "editor.minimap.renderCharacters": false,
    "editor.minimap.maxColumn": 200,
    "editor.minimap.showSlider": "always",
    "editor.semanticHighlighting.enabled": true,
    "editor.quickSuggestions": {
        "other": true,
        "comments": true,
        "strings": true
    },
    "search.exclude": {
        "**/.git": true,
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true
    },
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/node_modules": true,
        "**/.DS_Store": true
    },
    "files.insertFinalNewline": true,
    "files.enableTrash": false,
    "files.eol": "\n",
    "files.trimTrailingWhitespace": true,
    "workbench.activityBar.visible": true,
    "workbench.sideBar.location": "left",
    "workbench.tree.renderIndentGuides": "none",
    "workbench.colorTheme": "Default Dark+",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.settings.enableNaturalLanguageSearch": false,
    "terminal.integrated.fontFamily": "Iosevka",
    "terminal.integrated.fontSize": 20,
    "terminal.integrated.shell.windows": "C:\\Windows\\System32\\cmd.exe",
    "breadcrumbs.enabled": false,
    "zenMode.centerLayout": false,
    "zenMode.hideLineNumbers": false,
    "window.zoomLevel": 0,
    "extensions.ignoreRecommendations": true,
    "telemetry.enableCrashReporter": false,
    "telemetry.enableTelemetry": false,
    // file
    "[html]": {
        "editor.tabSize": 2
    },
    "[css]": {
        "editor.tabSize": 2
    },
    "[javascript]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2
    },
    "[typescript]": {
        "editor.tabSize": 2
    },
    "[javascriptreact]": {
        "editor.tabSize": 2
    },
    "[typescriptreact]": {
        "editor.tabSize": 2
    },
    "[vue]": {
        "editor.tabSize": 2
    },
    "[go]": {
        "editor.tabSize": 4,
        "editor.codeActionsOnSave": {
            "source.organizeImports": true
        }
    },
    // golang
    "go.goroot": "C:\\Program Files\\go",
    "go.gopath": "C:\\go",
    "go.lintTool": "golint",
    "go.lintFlags": [
        "--exclude=\"\bexported \\w+ (\\S*['.]*)([a-zA-Z'.*]*) should have comment or be unexported\b\""
    ],
    "go.formatTool": "goimports",
    "go.useLanguageServer": true,
    "go.languageServerExperimentalFeatures": {
        "format": true,
        "diagnostics": true,
        "documentLink": true
    },
    // ts/js
    "typescript.locale": "en",
    "typescript.tsdk": "C:\\Users\\kevin\\AppData\\Roaming\\npm\\node_modules\\typescript\\lib",
    "typescript.referencesCodeLens.enabled": true,
    "typescript.referencesCodeLens.showOnAllFunctions": true,
    "typescript.implementationsCodeLens.enabled": true,
    // emmet
    // "emmet.triggerExpansionOnTab": true,
    "emmet.showSuggestionsAsSnippets": true,
    "emmet.includeLanguages": {
        "javascript": "javascriptreact",
        "vue-html": "html",
        "razor": "html",
        "plaintext": "pug"
    },
    // live server
    "liveServer.settings.donotShowInfoMsg": true
}
